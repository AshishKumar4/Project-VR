From: Ashish Kumar Singh <ashishkmr472@gmail.com>
Date: Sat, 23 May 2026 13:00:00 +0000
Subject: [PATCH] backends/monitor: guard meta_monitor_mode_foreach_{crtc,output}
 against a NULL/transient current mode

meta_logical_monitor_foreach_crtc() (called during
meta_monitor_manager_rebuild) does:

    mode = meta_monitor_get_current_mode (monitor);
    meta_monitor_mode_foreach_crtc (monitor, mode, ...);

with no NULL check on @mode. A monitor can legitimately have NO current
mode during a reconfiguration -- e.g. when the G2 HMD's flaky DSC/EDID
handshake makes mutter rebuild mid-flight, or when the VR launcher dips
the desktop and a monitor is briefly without an is-current config
(journal: "<monitor> has no configuration which is-current!"). The NULL
@mode is then dereferenced inside meta_monitor_mode_foreach_crtc via
meta_monitor_mode_get_instance_private(mode), crashing gnome-shell
(SIGSEGV at meta_monitor_mode_foreach_crtc <- meta_monitor_manager_rebuild
<- meta_monitor_manager_apply_monitors_config).

Harden both meta_monitor_mode_foreach_crtc and the identical
meta_monitor_mode_foreach_output: treat a NULL monitor/mode as "no CRTCs
to iterate" (return TRUE) rather than dereferencing it, and bound the
output loop by mode_priv->n_crtc_modes so a monitor whose outputs list
changed after the mode's crtc_modes was sized cannot read past the array.
Also skip a monitor with no current mode at the caller so it does not log
spurious criticals.

Same class as the existing logical-monitor / wayland-outputs NULL guards
(G2 transient-state hardening); not yet upstreamed.
--- a/src/backends/meta-monitor.c
+++ b/src/backends/meta-monitor.c
@@ -2684,14 +2684,25 @@
                                 gpointer              user_data,
                                 GError              **error)
 {
-  MetaMonitorPrivate *monitor_priv =
-    meta_monitor_get_instance_private (monitor);
-  MetaMonitorModePrivate *mode_priv =
-    meta_monitor_mode_get_instance_private (mode);
+  MetaMonitorPrivate *monitor_priv;
+  MetaMonitorModePrivate *mode_priv;
   GList *l;
   int i;
 
-  for (l = monitor_priv->outputs, i = 0; l; l = l->next, i++)
+  /* G2/HMD hotplug: a monitor can transiently have no current mode during a
+   * reconfiguration (journal: "<monitor> has no configuration which is-current"),
+   * and a caller (meta_logical_monitor_foreach_crtc) passes that NULL mode
+   * straight here -> NULL deref. Treat a NULL mode/monitor as zero CRTCs to
+   * iterate (vacuously succeed) rather than crashing the whole compositor. */
+  if (!monitor || !mode)
+    return TRUE;
+
+  monitor_priv = meta_monitor_get_instance_private (monitor);
+  mode_priv = meta_monitor_mode_get_instance_private (mode);
+
+  for (l = monitor_priv->outputs, i = 0;
+       l && i < (int) mode_priv->n_crtc_modes;
+       l = l->next, i++)
     {
       MetaMonitorCrtcMode *monitor_crtc_mode = &mode_priv->crtc_modes[i];
 
@@ -2712,14 +2723,21 @@
                                   gpointer              user_data,
                                   GError              **error)
 {
-  MetaMonitorPrivate *monitor_priv =
-    meta_monitor_get_instance_private (monitor);
-  MetaMonitorModePrivate *mode_priv =
-    meta_monitor_mode_get_instance_private (mode);
+  MetaMonitorPrivate *monitor_priv;
+  MetaMonitorModePrivate *mode_priv;
   GList *l;
   int i;
 
-  for (l = monitor_priv->outputs, i = 0; l; l = l->next, i++)
+  /* Same transient-no-current-mode guard as meta_monitor_mode_foreach_crtc. */
+  if (!monitor || !mode)
+    return TRUE;
+
+  monitor_priv = meta_monitor_get_instance_private (monitor);
+  mode_priv = meta_monitor_mode_get_instance_private (mode);
+
+  for (l = monitor_priv->outputs, i = 0;
+       l && i < (int) mode_priv->n_crtc_modes;
+       l = l->next, i++)
     {
       MetaMonitorCrtcMode *monitor_crtc_mode = &mode_priv->crtc_modes[i];
 
--- a/src/backends/meta-logical-monitor.c
+++ b/src/backends/meta-logical-monitor.c
@@ -269,6 +269,11 @@
       };
 
       mode = meta_monitor_get_current_mode (monitor);
+      /* A monitor can transiently lack a current mode during a G2/HMD
+       * reconfiguration ("<monitor> has no configuration which is-current");
+       * skip it rather than passing NULL into foreach_crtc (which would deref it). */
+      if (!mode)
+        continue;
       meta_monitor_mode_foreach_crtc (monitor, mode, foreach_crtc, &data, NULL);
     }
 }
