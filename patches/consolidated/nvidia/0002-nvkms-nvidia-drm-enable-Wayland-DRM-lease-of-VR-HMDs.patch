@@ -1689,10 +1692,74 @@ static void nv_drm_finish_revoking_objects(struct drm_device *dev,
 #endif
 }
 
+/*
+ * After CREATE_LEASE, mark each leased CRTC's apiHead lesseeFlipPermissive so
+ * the lessee's separate NVKMS popen (e.g. libnvidia-vulkan.so on the
+ * VK_KHR_display path) can flip without a GRANT_PERMISSIONS handshake.
+ */
+static void nv_drm_finish_creating_lease(struct drm_device *dev,
+                                         struct drm_file *filep,
+                                         unsigned int cmd, unsigned long arg)
+{
+    unsigned int ioc_size;
+    struct drm_mode_create_lease create_lease;
+    struct drm_master *lessor, *lessee;
+    struct nv_drm_device *nv_dev = to_nv_device(dev);
+    struct drm_crtc *crtc;
+#if NV_DRM_MODESET_LOCK_ALL_END_ARGUMENT_COUNT == 3
+    int ret = 0;
+    struct drm_modeset_acquire_ctx ctx;
+#endif
+
+    ioc_size = _IOC_SIZE(cmd);
+    if (ioc_size > sizeof(create_lease)) {
+        return;
+    }
+    if (copy_from_user(&create_lease, (void __user *)arg, ioc_size) != 0) {
+        return;
+    }
+
+    lessor = nv_drm_file_get_master(filep);
+    if (lessor == NULL) {
+        return;
+    }
+
+    mutex_lock(&dev->mode_config.idr_mutex);
+    lessee = nv_drm_find_lessee(lessor, create_lease.lessee_id);
+    if (lessee == NULL) {
+        mutex_unlock(&dev->mode_config.idr_mutex);
+        return;
+    }
+
+#if NV_DRM_MODESET_LOCK_ALL_END_ARGUMENT_COUNT == 3
+    DRM_MODESET_LOCK_ALL_BEGIN(dev, ctx, DRM_MODESET_ACQUIRE_INTERRUPTIBLE,
+                               ret);
+#else
+    mutex_lock(&dev->mode_config.mutex);
+#endif
+
+    nv_drm_for_each_crtc(crtc, dev) {
+        if (idr_find(&lessee->leases, crtc->base.id) != NULL) {
+            struct nv_drm_crtc *nv_crtc = to_nv_crtc(crtc);
+            nvKms->setLesseeFlipPermissive(nv_dev->pDevice, nv_crtc->head,
+                                           NV_TRUE);
+        }
+    }
+
+#if NV_DRM_MODESET_LOCK_ALL_END_ARGUMENT_COUNT == 3
+    DRM_MODESET_LOCK_ALL_END(dev, ctx, ret);
+#else
+    mutex_unlock(&dev->mode_config.mutex);
+#endif
+    mutex_unlock(&dev->mode_config.idr_mutex);
+}
+
 /*
  * Wrapper around drm_ioctl to hook in to upstream ioctl.
  *
- * Currently used to add additional handling to REVOKE_LEASE.
+ * Used to add additional handling to CREATE_LEASE and REVOKE_LEASE: bridge
+ * DRM-lease state to NVKMS flip permissions so the lessee's separate
+ * /dev/nvidia-modeset fd can flip on leased heads.
  */
 static long nv_drm_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 {
@@ -1704,7 +1771,6 @@ static long nv_drm_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
     int objects_count = 0;
 
     if (cmd == DRM_IOCTL_MODE_REVOKE_LEASE) {
-        // Save the revoked objects before revoking.
         nv_drm_get_revoked_objects(dev, file_priv, cmd, arg, &objects,
                                    &objects_count);
     }
@@ -1713,11 +1779,12 @@ static long nv_drm_ioctl(struct file *filp, unsigned int cmd, unsigned long arg)
 
     if (cmd == DRM_IOCTL_MODE_REVOKE_LEASE && objects) {
         if (retcode == 0) {
-            // If revoking was successful, finish revoking the objects.
             nv_drm_finish_revoking_objects(dev, file_priv, objects,
                                            objects_count);
         }
         nv_drm_free(objects);
+    } else if (cmd == DRM_IOCTL_MODE_CREATE_LEASE && retcode == 0) {
+        nv_drm_finish_creating_lease(dev, file_priv, cmd, arg);
     }
 
     return retcode;
