+                if (area > bestArea ||
+                    (area == bestArea && t->etc.rrx1k > bestRrx1k)) {
+                    bestArea = area;
+                    bestRrx1k = t->etc.rrx1k;
+                    preferredVrModeIndex = j;
+                }
+            }
+        }
+    }
+
