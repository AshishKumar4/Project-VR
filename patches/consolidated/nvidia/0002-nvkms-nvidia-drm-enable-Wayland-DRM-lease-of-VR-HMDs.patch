+/*
+ * NVKMS_IOCTL_SET_LESSEE_FLIP_PERMISSIVE
+ *
+ * Set/clear an apiHead's lesseeFlipPermissive flag. When set,
+ * nvCheckLayerPermissions() returns TRUE for any popen on that head, bridging
+ * DRM lease (master rights on leased objects) and NVKMS per-popen permissions
+ * (which normally require a GRANT_PERMISSIONS handshake the DRM-lease path
+ * never triggers). Called by nv_drm from CREATE_LEASE / REVOKE_LEASE. Kernel-
+ * mode clients only.
+ */
+
+struct NvKmsSetLesseeFlipPermissiveRequest {
+    NvKmsDeviceHandle deviceHandle;
+    NvU32 apiHead;
+    NvBool permissive;
+};
+
+struct NvKmsSetLesseeFlipPermissiveReply {
+    NvU32 padding;
+};
+
+struct NvKmsSetLesseeFlipPermissiveParams {
+    struct NvKmsSetLesseeFlipPermissiveRequest request;
+    struct NvKmsSetLesseeFlipPermissiveReply reply;
+};
+
 #endif /* NVKMS_API_H */
