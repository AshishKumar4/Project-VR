diff --git a/src/nvidia-modeset/src/nvkms-modepool.c b/src/nvidia-modeset/src/nvkms-modepool.c
index c88bac93..8ee39305 100644
--- a/src/nvidia-modeset/src/nvkms-modepool.c
+++ b/src/nvidia-modeset/src/nvkms-modepool.c
@@ -354,6 +354,52 @@ ValidateModeIndexEdid(NVDpyEvoPtr pDpyEvo,
         return FALSE;
     }
 
+    /*
+     * G2-Linux fix: for VR headsets, flag the native (highest-resolution)
+     * panel mode as preferred.
+     *
+     * VR HMDs (HP Reverb G2, other Windows Mixed Reality headsets, ...)
+     * advertise their full-resolution native panel mode through a DisplayID
+     * timing block (DisplayID 1.x Type I or DisplayID 2.0 Type VII), while
+     * the EDID base block's preferred detailed timing is a lower-resolution
+     * compatibility mode. VR compositors that search only an output's
+     * *preferred* RandR modes when looking for a direct-mode HMD display —
+     * SteamVR's vrcompositor in particular — can never select the native
+     * mode unless it is flagged preferred.
+     *
+     * The display itself identifies as a headset via the Microsoft VR
+     * Vendor-Specific Data Block (CTA-861 extension), so this is scoped to
+     * VR/AR HMDs and never alters preferred-mode reporting for ordinary
+     * monitors. For an HMD the highest-resolution timing is by definition
+     * the native panel mode, regardless of which block carried it, so we
+     * pick the largest mode by area then refresh rate. Additive: the EDID
+     * DTD preferred flag, set further down, is left intact.
+     */
