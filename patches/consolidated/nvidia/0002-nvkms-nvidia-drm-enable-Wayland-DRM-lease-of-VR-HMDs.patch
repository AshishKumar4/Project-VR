diff --git a/src/nvidia-modeset/src/nvkms.c b/src/nvidia-modeset/src/nvkms.c
index 865fbf05..89b80896 100644
--- a/src/nvidia-modeset/src/nvkms.c
+++ b/src/nvidia-modeset/src/nvkms.c
@@ -4930,6 +4930,32 @@ static NvBool FramebufferConsoleDisabled(
     return TRUE;
 }
 
+static NvBool SetLesseeFlipPermissive(
+    struct NvKmsPerOpen *pOpen,
+    void *pParamsVoid)
+{
+    const struct NvKmsSetLesseeFlipPermissiveParams *pParams = pParamsVoid;
+    struct NvKmsPerOpenDev *pOpenDev =
+        GetPerOpenDev(pOpen, pParams->request.deviceHandle);
+
+    if (pOpenDev == NULL) {
+        return FALSE;
+    }
+    if (pOpen->clientType != NVKMS_CLIENT_KERNEL_SPACE) {
+        return FALSE;
+    }
+    if (!nvKmsOpenDevHasSubOwnerPermissionOrBetter(pOpenDev)) {
+        return FALSE;
+    }
+    if (pParams->request.apiHead >= ARRAY_LEN(pOpenDev->pDevEvo->apiHead)) {
+        return FALSE;
+    }
+
+    pOpenDev->pDevEvo->apiHead[pParams->request.apiHead].lesseeFlipPermissive =
+        pParams->request.permissive;
+    return TRUE;
+}
