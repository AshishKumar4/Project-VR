diff --git a/src/common/modeset/timing/nvt_edidext_861.c b/src/common/modeset/timing/nvt_edidext_861.c
index bf262514..00d07089 100644
--- a/src/common/modeset/timing/nvt_edidext_861.c
+++ b/src/common/modeset/timing/nvt_edidext_861.c
@@ -3800,15 +3800,21 @@ void parseEdidMsftVsdbBlock(VSDB_DATA *pVsdb, MSFT_VSDB_PARSED_INFO *pVsdbInfo)
 
             pVsdbInfo->desktopUsage = pMsftVsdbPayload->desktopUsage;
             pVsdbInfo->thirdPartyUsage = pMsftVsdbPayload->thirdPartyUsage;
-            pVsdbInfo->valid = NV_TRUE;
-        }
-        // Version 3 is the latest version of MSFT VSDB at the time of writing this code
-        // Any update from newer version will be ignored and be parsed as Version 3, till
-        // we have an explicit handling for newer version here.
-        if (pVsdbInfo->version >= 3)
-        {
-            // Primary Use case is valid from Version 3 and is ignored on previous versions.
+
+            // G2-Linux fix: the Primary Use Case is a fixed 5-bit field in the
+            // second payload byte (NVT_MSFT_VSDB_PAYLOAD::primaryUseCase) and
+            // is present for every VSDB version, not just version 3. Windows
+            // Mixed Reality headsets (HP Reverb G2, Samsung Odyssey, ...) ship
+            // a version-1 MSFT VSDB with this byte set to
+            // MSFT_VSDB_FOR_VIRTUAL_REALITY_HEADSETS, and edid-decode reads it
+            // unconditionally. Reading it for version >= 1 is safe: devices
+            // that predate the field leave those bits 0 (UNDEFINED). Without
+            // this, NVT cannot identify a VR headset and downstream consumers
+            // (e.g. preferred-mode selection for the native panel resolution)
+            // cannot special-case it.
             pVsdbInfo->primaryUseCase = pMsftVsdbPayload->primaryUseCase;
+
+            pVsdbInfo->valid = NV_TRUE;
         }
     }
 }
diff --git a/src/nvidia-modeset/src/nvkms-evo3.c b/src/nvidia-modeset/src/nvkms-evo3.c
index 13c5b1f0..06fa4a15 100644
--- a/src/nvidia-modeset/src/nvkms-evo3.c
+++ b/src/nvidia-modeset/src/nvkms-evo3.c
@@ -7214,10 +7214,13 @@ static void EvoSetDpDscParams(const NVDispEvoRec *pDispEvo,
 
     nvAssert(pDscInfo->type == NV_DSC_INFO_EVO_TYPE_DP);
 
-    // XXX: I'm pretty sure that this is wrong.
-    // BitsPerPixelx16 is something like (24 * 16) = 384, and 2 << (384 - 8) is
-    // an insanely large number.
-    flatnessDetThresh = (2 << (pDscInfo->dp.bitsPerPixelX16 - 8)); /* ??? */
+    // Fix: use bits_per_component from PPS byte 3 [7:4], not bitsPerPixelX16.
+    // DSC spec: flatness_det_thresh = 2 << (bpc - 8).
+    // PPS DW[0] packs bytes [3][2][1][0] as [31:24][23:16][15:8][7:0].
+    {
+        NvU32 bpc = (pDscInfo->dp.pps[0] >> 28) & 0xF; // PPS byte 3 bits[7:4]
+        flatnessDetThresh = (bpc >= 8) ? (2 << (bpc - 8)) : 2;
+    }
 
     nvAssert((pDscInfo->dp.dscMode == NV_DSC_EVO_MODE_DUAL) ||
                 (pDscInfo->dp.dscMode == NV_DSC_EVO_MODE_SINGLE));
