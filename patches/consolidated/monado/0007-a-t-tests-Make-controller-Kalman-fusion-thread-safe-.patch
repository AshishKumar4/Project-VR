+	void
+	KalmanFusion::publish_snapshot()
+	{
+		FilterSnapshot s;
+		Eigen::Map<Vector3d>{s.position} = filter_state.position();
+		Eigen::Map<Quaterniond>{s.orientation} = filter_state.getCombinedQuaternion();
+		Eigen::Map<Vector3d>{s.linear_velocity} = filter_state.velocity();
+		Eigen::Map<Vector3d>{s.angular_velocity} = filter_state.angularVelocity();
+		Eigen::Map<Vector3d>{s.acceleration} = filter_state.acceleration();
+		Eigen::Map<Vector3d>{s.last_good_position} = last_good_position;
+		s.filter_time_ns = filter_time_ns;
+		s.last_optical_ns = last_optical_ns;
+		s.tracked = tracked;
+		s.position_valid = position_state.valid;
+		s.position_tracked = position_state.tracked;
+		s.orientation_valid = orientation_state.valid;
+		s.orientation_tracked = orientation_state.tracked;
+
+		// Seqlock write: bump the counter odd, copy the body, bump it even.
+		// A reader that sees an odd counter, or a counter that changed
+		// across its copy, retries. Only the flat ~200-byte struct copy is
+		// inside the critical section, so the reader's spin window is a
+		// few ns.
+		uint32_t seq = m_snapshot_seq.load(std::memory_order_relaxed);
+		m_snapshot_seq.store(seq + 1, std::memory_order_relaxed);
+		std::atomic_thread_fence(std::memory_order_release);
+		m_snapshot = s;
+		std::atomic_thread_fence(std::memory_order_release);
+		m_snapshot_seq.store(seq + 2, std::memory_order_relaxed);
+	}
+
+	FilterSnapshot
+	KalmanFusion::read_snapshot() const
+	{
+		FilterSnapshot s;
+		uint32_t seq1, seq2;
+		do {
+			seq1 = m_snapshot_seq.load(std::memory_order_acquire);
+			while (seq1 & 1u) { // a publish is in progress
+				seq1 = m_snapshot_seq.load(std::memory_order_acquire);
+			}
+			s = m_snapshot;
+			std::atomic_thread_fence(std::memory_order_acquire);
+			seq2 = m_snapshot_seq.load(std::memory_order_relaxed);
+		} while (seq1 != seq2);
+		return s;
+	}
+
