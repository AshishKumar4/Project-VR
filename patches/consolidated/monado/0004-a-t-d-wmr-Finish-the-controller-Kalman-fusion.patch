-		Vector3d gyro = map_vec3_f64(sample.gyro_rad_secs);
-
-		// TODO: Figure out the acceleration.
-		acc = Vector3d::Zero();
-
-		gyro = filter_state.getQuaternion() * gyro;
+		// Gyro is rotated into the world frame to match the state's
