@@ -430,14 +464,26 @@ namespace {
 			orientation_variance = map_vec3(*orientation_variance_optional).cast<double>();
 		}
 
+		// With continuous IMU integration (see process_imu_data) the filter
+		// time tracks the most recent IMU sample, so an optical pose —
+		// timestamped when its camera frame was captured — normally arrives
+		// slightly "in the past" relative to filter_time_ns. We still apply
