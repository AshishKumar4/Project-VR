@@ -185,6 +185,34 @@ namespace {
 	public:
 		EIGEN_MAKE_ALIGNED_OPERATOR_NEW
 
+		KalmanFusion()
+		{
+			// The stock PoseSeparatelyDampedConstantVelocity damping
+			// (0.3 linear / 0.01 angular) attenuates velocity to ~30 %
+			// per second and angular velocity to ~1 % per second. That
+			// is far too aggressive for a VR controller in sustained
+			// motion: it continuously crushes the velocity estimate, so
+			// the filter lags real motion and the forward prediction is
+			// short. Use gentle damping (~0.95/s retention, ~19 s time
+			// constant) so genuine motion is preserved while a runaway
+			// velocity during a long optical dropout still bleeds off.
+			// combined_process_model holds a *reference* to
+			// main_process_model, so this configures both the predict
+			// and the prediction-extrapolation paths.
+			main_process_model.setDamping(0.95, 0.95);
+
+			// Process-noise autocorrelation. The stock 0.01 linear value
+			// makes the filter badly over-confident: its velocity
+			// estimate converges over several seconds, so it lags real
+			// motion (a controller can change velocity in tens of ms).
+			// A larger value lets position/IMU measurements update the
+			// velocity estimate quickly. Bracketed by the test suite:
+			// large enough that constant-velocity motion is tracked
+			// without lag, small enough that noisy optical poses are
+			// still smoothed.
+			main_process_model.setNoiseAutocorrelation(1.0, 0.5);
+		}
+
 		void
 		clear_position_tracked_flag() override;
 
